# vLLM CPU image for IBM Power (ppc64le)
#
# Based on:
#   https://community.ibm.com/community/user/blogs/maryam-nezamabadi/2026/02/09/set-up-and-run-vllm-on-ibm-power
#
# Produces a drop-in replacement for: icr.io/ppc64le-oss/vllm-ppc64le
#
# Build:
#   podman build -t localhost/vllm-ppc64le:dev .
#
# Run:
#   podman run --rm -v /var/lib/ai-services/models:/models:Z -p 8000:8000 \
#     localhost/vllm-ppc64le:dev \
#     vllm serve /models/ibm-granite/granite-3.3-8b-instruct \
#       --dtype bfloat16 --max-model-len 8192 --port 8000

ARG BASE_IMAGE=registry.access.redhat.com/ubi9/ubi:latest
ARG VLLM_VERSION=v0.11.1
ARG PYTHON_VERSION=3.12

FROM ${BASE_IMAGE}

ARG VLLM_VERSION
ARG PYTHON_VERSION

# Install all system dependencies (build + runtime)
RUN dnf install -y \
        gcc-toolset-14 \
        gcc-toolset-14-libatomic-devel \
        gcc-toolset-14-binutils \
        python${PYTHON_VERSION} \
        python${PYTHON_VERSION}-devel \
        python${PYTHON_VERSION}-pip \
        git \
        cmake \
        make \
        numactl \
        numactl-devel \
        openblas-devel \
        openssl-devel \
        libffi-devel \
        zlib-devel \
        libatomic \
        libgfortran \
        rust \
        cargo \
        ninja-build \
    && dnf clean all \
    && ln -sf /usr/lib64/libatomic.so.1 /usr/lib64/libatomic.so \
    && cp /opt/rh/gcc-toolset-14/root/usr/lib64/libctf.so.0* /usr/lib64/ 2>/dev/null \
    || ln -sf /opt/rh/gcc-toolset-14/root/usr/lib64/libctf.so.0 /usr/lib64/libctf.so.0 2>/dev/null \
    || true

# Activate gcc-toolset-14
ENV PATH="/opt/rh/gcc-toolset-14/root/usr/bin:${PATH}" \
    CC=/opt/rh/gcc-toolset-14/root/usr/bin/gcc \
    CXX=/opt/rh/gcc-toolset-14/root/usr/bin/g++ \
    LD_LIBRARY_PATH="/opt/rh/gcc-toolset-14/root/usr/lib64:/opt/rh/gcc-toolset-14/root/usr/lib"

# Create and activate virtual environment
RUN python${PYTHON_VERSION} -m venv /opt/vllm-venv
ENV VIRTUAL_ENV=/opt/vllm-venv \
    PATH="/opt/vllm-venv/bin:${PATH}"

RUN pip install --upgrade pip setuptools wheel setuptools-scm

# Tell grpcio to use system OpenSSL/zlib instead of bundled BoringSSL
# (BoringSSL does not compile on ppc64le)
ENV GRPC_PYTHON_BUILD_SYSTEM_OPENSSL=1 \
    GRPC_PYTHON_BUILD_SYSTEM_ZLIB=1

# Install Python dependencies from IBM Power wheels repository
COPY requirements.txt /tmp/requirements.txt
RUN pip install --prefer-binary \
        -r /tmp/requirements.txt \
        --extra-index-url=https://wheels.developerfirst.ibm.com/ppc64le/linux

# Build and install protobuf from source (not available as RPM on UBI9,
# and the IBM torch wheel expects it but doesn't bundle it)
ARG PROTOBUF_VERSION=25.6
RUN git clone --depth 1 --branch v${PROTOBUF_VERSION} \
        https://github.com/protocolbuffers/protobuf.git /tmp/protobuf \
    && cd /tmp/protobuf \
    && git submodule update --init --depth 1 \
    && cmake -B build -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr/local \
        -Dprotobuf_BUILD_TESTS=OFF \
        -Dprotobuf_ABSL_PROVIDER=module \
        -DCMAKE_POSITION_INDEPENDENT_CODE=ON \
    && cmake --build build -j$(nproc) \
    && cmake --install build \
    && rm -rf /tmp/protobuf

# Set library paths
ENV SITE_PACKAGE_PATH="/opt/vllm-venv/lib64/python${PYTHON_VERSION}/site-packages" \
    VLLM_TARGET_DEVICE=cpu

ENV LD_LIBRARY_PATH="/usr/local/lib64:/usr/local/lib:/usr/lib64:${SITE_PACKAGE_PATH}/openblas/lib:${SITE_PACKAGE_PATH}:${SITE_PACKAGE_PATH}/ffmpeg/lib:${SITE_PACKAGE_PATH}/libvpx/lib:${SITE_PACKAGE_PATH}/lame/lib:${LD_LIBRARY_PATH}" \
    CMAKE_PREFIX_PATH="/usr/local:${SITE_PACKAGE_PATH}/torch:${CMAKE_PREFIX_PATH}"

# Clone and build vLLM
RUN git clone --depth 1 --branch ${VLLM_VERSION} https://github.com/vllm-project/vllm.git /tmp/vllm

WORKDIR /tmp/vllm

RUN pip install --prefer-binary -r requirements/common.txt \
        --extra-index-url=https://wheels.developerfirst.ibm.com/ppc64le/linux

RUN VLLM_TARGET_DEVICE=cpu python3 setup.py install

# Clean up build artifacts to reduce image size
RUN rm -rf /tmp/vllm /tmp/pip-* /root/.cache/pip \
    && dnf remove -y python${PYTHON_VERSION}-devel gcc-toolset-14 rust cargo \
        cmake ninja-build make git \
        openssl-devel libffi-devel zlib-devel numactl-devel openblas-devel 2>/dev/null || true \
    && dnf clean all

RUN ldconfig

WORKDIR /

# vLLM CPU defaults
ENV VLLM_CPU_KVCACHE_SPACE=40 \
    VLLM_CPU_OMP_THREADS_BIND="auto" \
    PYTHONUNBUFFERED=1

EXPOSE 8000

# Default entrypoint matches what the ai-services templates expect
ENTRYPOINT ["/bin/sh", "-c"]
CMD ["vllm serve --help"]
