# Multi-stage build for wiki-service

# Stage 1: Build
FROM registry.access.redhat.com/ubi9/go-toolset:1.25 AS builder

WORKDIR /workspace

# Copy go mod files
COPY go.mod go.sum ./

# Download dependencies
RUN go mod download

# Copy source code
COPY . .

# Build the binary (let Go use native architecture)
RUN CGO_ENABLED=0 go build -o wiki-service ./cmd/wiki-service

# Stage 2: Runtime
FROM registry.access.redhat.com/ubi9/ubi-minimal:latest

WORKDIR /app

# Copy binary from builder
COPY --from=builder /workspace/wiki-service /app/wiki-service

# Create wiki data directory
RUN mkdir -p /data/wiki && \
    chown -R 1001:0 /data/wiki && \
    chmod -R g+rwX /data/wiki

# Use non-root user
USER 1001

# Expose API port (for future use)
EXPOSE 8080

# Set default environment variables
ENV WIKI_DATA_DIR=/data/wiki \
    LLM_ENDPOINT=http://vllm-server:8000 \
    LLM_MODEL=ibm-granite/granite-3.3-8b-instruct \
    LLM_MAX_TOKENS=4096 \
    LLM_TEMPERATURE=0.2 \
    LOG_LEVEL=info

# Run the service
CMD ["/app/wiki-service"]