apiVersion: v1
kind: Pod
metadata:
  name: "{{ .AppName }}--agent"
  labels:
    ai-services.io/application: "{{ .AppName }}"
    ai-services.io/template: "{{ .AppTemplateName }}"
    ai-services.io/version: "{{ .Version }}"
  annotations:
    ai-services.io/ports: "{{ or .Values.agent.port }}:9000"
spec:
  containers:
    - name: agent
      image: "{{ .Values.agent.image }}"
      command:
        - "python"
        - "-m"
        - "agent.main"
      env:
        - name: LLM_PROVIDER
          value: "vllm"
        - name: LLM_ENDPOINT
          value: "http://{{ .AppName }}--vllm-server:8000"
        - name: LLM_MODEL
          value: "ibm-granite/granite-3.3-8b-instruct"
        - name: SUMMARIZE_ENDPOINT
          value: "http://{{ .AppName }}--summarize-api:6000"
        - name: AGENT_PORT
          value: "9000"
        - name: LOG_LEVEL
          value: "{{ .Values.agent.log_level }}"
      resources:
        requests:
          memory: "256Mi"
        limits:
          memory: "512Mi"
      ports:
        - containerPort: 9000
          protocol: TCP
      livenessProbe:
        httpGet:
          path: /.well-known/agent-card.json
          port: 9000
        initialDelaySeconds: 10
        periodSeconds: 30
        timeoutSeconds: 5
        failureThreshold: 3